}

int bills()
{
    int ch;

    printf("\n\n Choose bill receipt format");
    printf("\n Press 1 for OFFLINE bill");
    printf("\n Press 2 for ONLINE bill");
    scanf("%d",&ch);

    if(ch == 1)
        return 1;
    else if(ch == 2)
        return 0;
    else
        return -1;
}

