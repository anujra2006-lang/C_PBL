#include <stdio.h>
#include <string.h>


struct Customer {
    char name[100];
    char address[150];
    char phone[20];
};

struct Item {
    int   id;
    char  name[100];
    float quantity;
    char  unit[20];      
    float price;
};

int main() {

    struct Customer customer;
    int   totalItems;
    float total = 0, tax = 0, grandTotal = 0;

    // ══════════════════════════════════════════
    //            CUSTOMER INFORMATION
    // ══════════════════════════════════════════
    printf("\n+----------------------------------+\n");
    printf("|    CUSTOMER BILLING SYSTEM       |\n");
    printf("+----------------------------------+\n\n");

    printf("Enter Name    : ");
    scanf(" %99[^\n]", customer.name);

    printf("Enter Address : ");
    scanf(" %149[^\n]", customer.address);

    printf("Enter Phone   : ");
    scanf(" %19[^\n]", customer.phone);

    // ══════════════════════════════════════════
    //              ITEM DETAILS
    // ══════════════════════════════════════════
    printf("\nHow many items : ");
    scanf("%d", &totalItems);

    struct Item items[totalItems];

    printf("\n--- Enter Item Details ---\n");

    for (int i = 0; i < totalItems; i++) {
        char hasUnit;
        items[i].id = i + 1;

        printf("\nItem %d:\n", i + 1);

        printf("  Name              : ");
        scanf(" %99[^\n]", items[i].name);

        printf("  Quantity          : ");
        scanf("%f", &items[i].quantity);

        // ── Ask if unit is needed ──
        printf("  Has unit? (y/n)   : ");
        scanf(" %c", &hasUnit);

        if (hasUnit == 'y' || hasUnit == 'Y') {
            printf("  Unit (kg/g/L/etc) : ");
            scanf(" %19s", items[i].unit);
        } else {
            // no unit — store empty string
            strcpy(items[i].unit, "");
        }

        printf("  Price per item    : ");
        scanf("%f", &items[i].price);
    }

    
    printf("\n\n");
    printf("+===============================================+\n");
    printf("|             BILL           |\n");
    printf("+===============================================+\n");
    printf("  Name    : %s\n", customer.name);
    printf("  Address : %s\n", customer.address);
    printf("  Phone   : %s\n", customer.phone);
    printf("+-----------------------------------------------+\n");
    printf("| %-4s | %-15s | %-8s | %-6s | %-8s |\n",
           "ID", "Item Name", "Qty", "Price", "Subtotal");
    printf("+-----------------------------------------------+\n");

    for (int i = 0; i < totalItems; i++) {

        // ── Build quantity display string ──
        char qtyDisplay[30];
        if (strlen(items[i].unit) > 0) {
            // has unit  → "10.0 kg"
            sprintf(qtyDisplay, "%.1f %s", items[i].quantity, items[i].unit);
        } else {
            // no unit   → "3"
            sprintf(qtyDisplay, "%.0f", items[i].quantity);
        }

        float subtotal = items[i].quantity * items[i].price;
        total += subtotal;

        printf("| %-4d | %-15s | %-8s | %-6.2f | %-8.2f |\n",
               items[i].id,
               items[i].name,
               qtyDisplay,
               items[i].price,
               subtotal);
    }

    tax        = total * 0.05f;
    grandTotal = total + tax;

    printf("+-----------------------------------------------+\n");
    printf("  Subtotal    : %.2f\n", total);
    printf("  Tax (5%%)    : %.2f\n", tax);
    printf("  Grand Total : %.2f\n", grandTotal);
    printf("+===============================================+\n");
    printf("|         Thanks for visiting us!             |\n");
    printf("+===============================================+\n\n");

    return 0;
}
